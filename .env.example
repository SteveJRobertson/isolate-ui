# LangChain & LLM API Keys
# Required for ai-orchestrator agent execution

# OpenAI API Key (for GPT-4o — primary LLM)
OPENAI_API_KEY=sk_test_...

# Anthropic API Key (for Claude 3.5 Sonnet — accessibility specialist)
ANTHROPIC_API_KEY=sk-ant-...

# GitHub Token (for posting comments during agent execution)
GITHUB_TOKEN=ghp_...

# Webhook Secret (for GitHub webhook listener — Issue #21)
WEBHOOK_SECRET=your_webhook_secret_here

# Optional: LangSmith tracing for debugging
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls...

# Optional: Tailscale Funnel endpoint (for webhook listener)
TAILSCALE_HOSTNAME=your-funnel-url.ts.net
