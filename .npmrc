# Hoist all dependencies to the root node_modules
# This is needed for Nx to properly resolve plugins and their dependencies
shamefully-hoist=true

# Alternative stricter approach (uncomment if shamefully-hoist causes issues):
# public-hoist-pattern[]=*@nx/*
# public-hoist-pattern[]=*vitest*
# public-hoist-pattern[]=*vite*

# NPM registry authentication (CI only - uses NODE_AUTH_TOKEN env var)
//registry.npmjs.org/:_authToken=${NODE_AUTH_TOKEN}