{
  "name": "react-button",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/react/button/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "codegen": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec panda codegen",
        "cwd": "{workspaceRoot}"
      },
      "outputs": ["{workspaceRoot}/styled-system"]
    },
    "storybook": {
      "executor": "nx:run-commands",
      "options": {
        "command": "storybook dev --port 6006 --config-dir .storybook",
        "cwd": "{workspaceRoot}"
      }
    },
    "build-storybook": {
      "executor": "nx:run-commands",
      "options": {
        "command": "storybook build --config-dir .storybook --output-dir dist/storybook/react-button",
        "cwd": "{workspaceRoot}"
      },
      "outputs": ["{workspaceRoot}/dist/storybook/react-button"]
    },
    "component-test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec playwright test -c playwright-ct.config.ts",
        "cwd": "{projectRoot}"
      },
      "dependsOn": [
        { "projects": ["@isolate-ui/source"], "target": "generate-styles" }
      ],
      "inputs": ["default"]
    },
    "nx-release-publish": {
      "options": {
        "packageRoot": "dist/{projectRoot}"
      }
    }
  },
  "release": {
    "version": {
      "manifestRootsToUpdate": ["dist/{projectRoot}"],
      "currentVersionResolver": "git-tag",
      "fallbackCurrentVersionResolver": "disk"
    }
  }
}
