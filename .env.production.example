# Production Environment Configuration Template
# 
# Copy this file to .env.production and fill in your actual values.
# IMPORTANT: .env.production is gitignored and should NOT be committed to the repository.
# Sensitive values (tokens, secrets) MUST be kept secure.

# ============================================================================
# REQUIRED VARIABLES
# The webhook-listener will exit immediately (process.exit(1)) if these are missing.
# ============================================================================

# GitHub Personal Access Token
# Create at: https://github.com/settings/tokens?type=beta
# Required scopes: repo (full control of repositories)
# Used to: Query GitHub API for missed comments during startup sync, post replies to issues
GITHUB_TOKEN=

# Webhook Secret
# Set this to match the secret in your GitHub webhook settings
# Minimum 32 characters recommended for security
# Used to: Verify HMAC-SHA256 signatures from GitHub webhook payloads
WEBHOOK_SECRET=

# ============================================================================
# OPTIONAL VARIABLES (with defaults)
# These have sensible defaults but can be overridden for special deployments.
# ============================================================================

# GitHub Repository Owner
# Default: resolved from code if unset — set this to target a different org or user
# Used to: Filter webhook events and GitHub API queries to the correct repository
GITHUB_OWNER=

# GitHub Repository Name
# Default: resolved from code if unset — set this to target a different repository
# Used to: Filter webhook events and GitHub API queries to the correct repository
GITHUB_REPO=

# HTTP Server Binding Address
# Default: 0.0.0.0 (bind all interfaces - required for external access)
# Options: 0.0.0.0 (public), 127.0.0.1 (localhost only), specific IP
# Used to: Fastify server bind address for incoming webhooks
HOST=0.0.0.0

# HTTP Server Port
# Default: 8080
# Used to: Fastify server listening port (must match Tailscale Funnel or reverse proxy)
PORT=8080

# SQLite Database Path
# Default: Resolved relative to workspace root via nx.json marker walk-up
# Falls back to: libs/ai-orchestrator/data/state.db
# Used to: Stores webhook deliveries (dedup table), LangGraph checkpoints, startup sync cursor
DATABASE_PATH=

# Startup Sync Window (milliseconds)
# Default: 3600000 (1 hour)
# Used to: Determines how far back to scan GitHub comments during server startup
# Increase if: Deployment downtime exceeded the default window and you want to replay older commands
# Note: Wider windows use more GitHub API quota
STARTUP_SYNC_WINDOW_MS=3600000

# ============================================================================
# OPTIONAL: AI/LLM API KEYS
# Only required if using specific LLM providers in the orchestrator.
# ============================================================================

# Anthropic Claude API Key
# Optional: Only needed if using Claude for agent orchestration
# Create at: https://console.anthropic.com/account/keys
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API Key
# Optional: Only needed if using GPT for agent orchestration
# Create at: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...

# ============================================================================
# OPTIONAL: DEBUGGING & OBSERVABILITY
# Enable for development and troubleshooting only.
# ============================================================================

# LangChain Tracing
# Default: false
# Set to: true to enable LangGraph execution tracing and debugging
# LANGCHAIN_TRACING_V2=false

# Node Environment
# Leave unset to use ecosystem.config.js NODE_ENV=production
# NODE_ENV=production
